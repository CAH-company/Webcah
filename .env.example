# ─── WYMAGANE ────────────────────────────────────────────────

# Webhook dla popupu lead i formularza kontaktowego (n8n / Make / Slack)
WEBHOOK_URL=https://hooks.your-tool.com/YOUR_WEBHOOK_URL

# Webhook dla ankiety satysfakcji
SURVEY_WEBHOOK_URL=https://hooks.your-tool.com/YOUR_SURVEY_WEBHOOK_URL

# Publiczny URL produkcyjny (używany do CSRF protection)
NEXT_PUBLIC_SITE_URL=https://www.polandautomationhub.pl

# ─── RATE LIMITING (Upstash Redis) ───────────────────────────
# Wymagane dla formularza kontaktowego. Darmowe konto: https://upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ─── OPCJONALNE ──────────────────────────────────────────────

# Microsoft Clarity — analytics / session recording
NEXT_PUBLIC_CLARITY_ID=

# Webhook dla formularza test-AI
AI_TEST_WEBHOOK_URL=
